// prisma/schema.prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── ENUMS ────────────────────────────────────────────────────────────────────

enum Role {
  SUPER_ADMIN
  ADMIN
  MANAGER
  AGENT
}

enum Plan {
  FREE
  BUSINESS
  ENTERPRISE
}

enum SubscriptionStatus {
  ACTIVE
  INACTIVE
  TRIAL
  CANCELLED
  PAST_DUE
}

enum AuditAction {
  USER_REGISTERED
  USER_LOGIN
  USER_LOGOUT
  USER_UPDATED
  PASSWORD_CHANGED
  PASSWORD_RESET_REQUESTED
  PASSWORD_RESET_COMPLETED
  ROLE_CHANGED
  PLAN_UPGRADED
  PLAN_DOWNGRADED
  LEAD_EXPORTED
  CAMPAIGN_CREATED
  CAMPAIGN_STARTED
  CAMPAIGN_PAUSED
  CAMPAIGN_STOPPED
  TEAM_MEMBER_INVITED
  TEAM_MEMBER_REMOVED
  WEBHOOK_CREATED
  CONTACT_IMPORTED
  SUBSCRIPTION_CREATED
  SUBSCRIPTION_CANCELLED
}

// ─── USER & AUTH ──────────────────────────────────────────────────────────────

model User {
  id                String   @id @default(uuid())
  email             String   @unique
  passwordHash      String
  fullName          String
  phone             String?
  countryCode       String?  @default("+91")
  country           String?
  age               Int?
  gender            String?
  address           String?
  avatarUrl         String?
  timezone          String   @default("Asia/Kolkata")
  theme             String   @default("dark")
  isEmailVerified   Boolean  @default(false)
  isActive          Boolean  @default(true)
  role              Role     @default(AGENT)
  organizationId    String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  // Relations
  organization      Organization?  @relation(fields: [organizationId], references: [id])
  refreshTokens     RefreshToken[]
  passwordResets    PasswordReset[]
  emailVerifications EmailVerification[]
  auditLogs         AuditLog[]     @relation("ActorLogs")
  subscription      Subscription?

  @@map("users")
}

model Organization {
  id          String   @id @default(uuid())
  name        String
  slug        String   @unique
  logoUrl     String?
  website     String?
  industry    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users       User[]
  subscription Subscription?

  @@map("organizations")
}

model RefreshToken {
  id          String   @id @default(uuid())
  token       String   @unique
  userId      String
  expiresAt   DateTime
  isRevoked   Boolean  @default(false)
  userAgent   String?
  ipAddress   String?
  createdAt   DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}

model PasswordReset {
  id          String   @id @default(uuid())
  token       String   @unique
  userId      String
  expiresAt   DateTime
  isUsed      Boolean  @default(false)
  createdAt   DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("password_resets")
}

model EmailVerification {
  id          String   @id @default(uuid())
  token       String   @unique
  userId      String
  expiresAt   DateTime
  isUsed      Boolean  @default(false)
  createdAt   DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("email_verifications")
}

// ─── PLANS & BILLING ──────────────────────────────────────────────────────────

model PlanConfig {
  id                  String @id @default(uuid())
  plan                Plan   @unique
  displayName         String
  priceMonthly        Float
  priceYearly         Float
  maxMessages         Int    // -1 = unlimited
  maxAgents           Int
  maxCampaigns        Int
  maxContacts         Int
  whatsappTemplates   Int
  canUseAI            Boolean @default(false)
  canUseCRM           Boolean @default(false)
  canExportLeads      Boolean @default(false)
  canUseAnalytics     Boolean @default(false)
  razorpayPlanId      String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@map("plan_configs")
}

model Subscription {
  id                  String             @id @default(uuid())
  userId              String             @unique
  organizationId      String?            @unique
  plan                Plan               @default(FREE)
  status              SubscriptionStatus @default(TRIAL)
  trialEndsAt         DateTime?
  currentPeriodStart  DateTime?
  currentPeriodEnd    DateTime?
  razorpaySubId       String?
  razorpayCustomerId  String?
  cancelledAt         DateTime?
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt

  user                User?              @relation(fields: [userId], references: [id])
  organization        Organization?      @relation(fields: [organizationId], references: [id])

  @@map("subscriptions")
}

model PaymentEvent {
  id            String   @id @default(uuid())
  provider      String   // razorpay | dodo
  eventType     String   // payment.captured, subscription.activated, etc.
  externalId    String   // razorpay payment_id / order_id
  payload       Json
  processed     Boolean  @default(false)
  processedAt   DateTime?
  createdAt     DateTime @default(now())

  @@map("payment_events")
}

// ─── AUDIT LOG ────────────────────────────────────────────────────────────────

model AuditLog {
  id          String      @id @default(uuid())
  actorId     String?
  action      AuditAction
  targetType  String?     // "User", "Campaign", "Lead", etc.
  targetId    String?
  metadata    Json?       // extra context (e.g. old vs new role)
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime    @default(now())

  actor       User?       @relation("ActorLogs", fields: [actorId], references: [id])

  @@index([actorId])
  @@index([action])
  @@index([createdAt])
  @@map("audit_logs")
}
